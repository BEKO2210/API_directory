---
import Page from '@layouts/Page.astro';
import { getSiteStats } from '@lib/getApis';

const stats = getSiteStats();
---

<Page
  title="Über uns"
  description="Erfahre mehr über API Hub — ein Projekt von Belkis Aslani zur besseren Visualisierung der public-apis Daten."
>
  <div style="max-width: 640px; margin: 0 auto;">
    <h1 style="font-size: 1.75rem; font-weight: 700; color: var(--text-1); margin: 0 0 0.75rem;">
      Über API Hub
    </h1>

    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0 0 1.5rem;">
      API Hub wurde von <strong style="color: var(--text-1);">Belkis Aslani</strong> ins Leben gerufen,
      um die umfangreiche Sammlung an kostenlosen, öffentlichen APIs aus dem
      <a href="https://github.com/public-apis/public-apis" target="_blank" rel="noopener noreferrer" style="color: var(--text-1); text-decoration: underline; text-underline-offset: 2px;">public-apis/public-apis</a>
      Repository besser zugänglich und durchsuchbar zu machen.
    </p>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Warum dieses Projekt?
    </h2>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0 0 1.5rem;">
      Das <a href="https://github.com/public-apis/public-apis" target="_blank" rel="noopener noreferrer" style="color: var(--text-1); text-decoration: underline; text-underline-offset: 2px;">public-apis</a>
      Repository ist mit über 300.000 Stars eines der beliebtesten Open-Source-Projekte auf GitHub.
      Es enthält eine riesige Liste an kostenlosen APIs — allerdings nur als Markdown-Tabelle in einer README-Datei.
      API Hub macht diese Daten durch eine moderne, schnelle und durchsuchbare Oberfläche deutlich
      besser nutzbar.
    </p>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Credits
    </h2>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0 0 1.5rem;">
      <strong style="color: var(--text-1);">Alle Credits gehen an das Original-Repository
      <a href="https://github.com/public-apis/public-apis" target="_blank" rel="noopener noreferrer" style="color: var(--text-1); text-decoration: underline; text-underline-offset: 2px;">public-apis/public-apis</a></strong>
      und dessen Community. Dieses Projekt visualisiert lediglich die dort gesammelten Daten.
      Wir erheben keinen Anspruch auf die API-Daten selbst.
    </p>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      So funktioniert's
    </h2>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0 0 1.5rem;">
      API Hub ist eine statische Website, gebaut mit Astro und gehostet auf GitHub Pages. Täglich
      synchronisiert ein automatisierter GitHub Actions Workflow die neuesten Daten aus dem public-apis
      Repository, parst die README und generiert die Website neu. Das bedeutet: keine Serverkosten
      und blitzschnelle Performance — jede Seite ist vorgerendertes HTML.
    </p>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Statistiken
    </h2>
    <div
      style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
      "
    >
      <div
        style="
          text-align: center;
          padding: 1.25rem;
          background: var(--surface);
          border-radius: var(--r-lg);
          border: 1px solid var(--border);
        "
      >
        <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin: 0;">
          {stats.totalAPIs.toLocaleString()}
        </p>
        <p style="font-size: 0.8125rem; color: var(--text-3); margin: 0.25rem 0 0;">APIs</p>
      </div>
      <div
        style="
          text-align: center;
          padding: 1.25rem;
          background: var(--surface);
          border-radius: var(--r-lg);
          border: 1px solid var(--border);
        "
      >
        <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin: 0;">
          {stats.totalCategories}
        </p>
        <p style="font-size: 0.8125rem; color: var(--text-3); margin: 0.25rem 0 0;">Kategorien</p>
      </div>
      <div
        style="
          text-align: center;
          padding: 1.25rem;
          background: var(--surface);
          border-radius: var(--r-lg);
          border: 1px solid var(--border);
        "
      >
        <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin: 0;">Täglich</p>
        <p style="font-size: 0.8125rem; color: var(--text-3); margin: 0.25rem 0 0;">Sync</p>
      </div>
    </div>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Tech Stack
    </h2>
    <ul style="padding-left: 1.25rem; margin: 0 0 2rem; color: var(--text-2); line-height: 1.8;">
      <li><strong style="color: var(--text-1);">Astro</strong> — Statische Seitengenerierung mit null Client-Side JS</li>
      <li><strong style="color: var(--text-1);">Tailwind CSS v4</strong> — Utility-First Styling</li>
      <li><strong style="color: var(--text-1);">Pagefind</strong> — Offline-Volltextsuche ohne Bundle-Overhead</li>
      <li><strong style="color: var(--text-1);">GitHub Actions</strong> — Tägliche Datensynchronisation</li>
      <li><strong style="color: var(--text-1);">GitHub Pages</strong> — Kostenloses, zuverlässiges Hosting</li>
    </ul>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Open Source
    </h2>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0;">
      API Hub ist Open Source unter der MIT-Lizenz. Der Quellcode ist verfügbar auf
      <a href="https://github.com/BEKO2210/API_directory" target="_blank" rel="noopener noreferrer" style="color: var(--text-1); text-decoration: underline; text-underline-offset: 2px;">GitHub</a>.
      Beiträge, Bug-Reports und Feature-Requests sind willkommen.
    </p>
  </div>
</Page>
