---
import Page from '@layouts/Page.astro';
---

<Page
  title="Legal Notice"
  description="Legal notice and site operator information for API Hub."
>
  <div style="max-width: 640px; margin: 0 auto;">
    <h1 style="font-size: 1.75rem; font-weight: 700; color: var(--text-1); margin: 0 0 0.75rem;">
      Legal Notice
    </h1>
    <p style="font-size: 0.875rem; color: var(--text-3); margin: 0 0 2rem;">
      Information in accordance with § 5 TMG (German Telemedia Act)
    </p>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Site Operator
    </h2>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0 0 1.5rem;">
      Belkis Aslani<br />
      Vogelsangstr. 32<br />
      71691 Freiberg am Neckar<br />
      Germany
    </p>

    <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1); margin: 0 0 0.75rem;">
      Contact
    </h2>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.7; margin: 0 0 1.5rem;">
      Email: <a href="mailto:belkis.aslani@gmail.com" style="color: var(--text-1); text-decoration: underline; text-underline-offset: 2px;">belkis.aslani@gmail.com</a>
