---
import Base from '@layouts/Base.astro';
import Hero from '@components/home/Hero.astro';
import StatsBar from '@components/home/StatsBar.astro';
import CategoryGrid from '@components/home/CategoryGrid.astro';
import { getAllCategories, getSiteStats } from '@lib/getApis';
import { getBaseUrl } from '@lib/utils';

const stats = getSiteStats();
const categories = getAllCategories();
const base = getBaseUrl();

const description = `Browse, search and filter ${stats.totalAPIs.toLocaleString()}+ free public APIs across ${stats.totalCategories}+ categories. The most complete directory of open APIs for developers.`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'API Hub',
  url: `https://beko2210.github.io${base}`,
  description: 'A curated directory of free public APIs for developers.',
  potentialAction: {
    '@type': 'SearchAction',
    target: `https://beko2210.github.io${base}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
});
---

<Base title="API Hub" description={description} jsonLd={jsonLd}>
  <Hero stats={stats} />
  <StatsBar stats={stats} />
  <CategoryGrid categories={categories} />

  <!-- CTA Section -->
  <section class="reveal" style="padding: 3rem 0;">
    <div
      class="container"
      style="
        max-width: 640px;
        text-align: center;
        padding: 2.5rem;
        background: var(--surface);
        border-radius: var(--r-xl);
        border: 1px solid var(--border);
      "
    >
      <h2
        style="
          font-size: 1.25rem;
          font-weight: 700;
          color: var(--text-1);
          margin: 0 0 0.75rem;
        "
      >
        Want to add your API?
      </h2>
      <p style="font-size: 0.9375rem; color: var(--text-3); margin: 0 0 1.25rem;">
        Submit a new free public API via our issue form — it gets added automatically on the next build.
      </p>
      <a
        href={`${base}/submit`}
        class="cta-button"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        Submit an API
      </a>
    </div>
  </section>
</Base>
