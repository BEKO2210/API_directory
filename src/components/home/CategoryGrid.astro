---
import type { Category } from '@lib/types';
import { getBaseUrl } from '@lib/utils';

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const base = getBaseUrl();
---

<section class="reveal" style="padding: 3rem 0;">
  <div class="container">
    <h2
      style="
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-1);
        margin: 0 0 1.5rem;
      "
    >
      Browse by Category
    </h2>
    <div
      style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 0.75rem;
      "
    >
      {
        categories.map((cat) => (
          <a
            href={`${base}/categories/${cat.slug}`}
            class="category-card"
          >
            <span class="category-card-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m13 2-2 2.5h3L12 7" />
                <circle cx="12" cy="14" r="4" />
              </svg>
            </span>
            <div style="flex: 1; min-width: 0;">
              <p class="category-card-name">
                {cat.name}
              </p>
              <p class="category-card-count">
                {cat.count} APIs
              </p>
            </div>
            <svg class="category-card-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .category-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    text-decoration: none;
    transition: box-shadow 250ms var(--ease), transform 250ms var(--ease),
      border-color 250ms var(--ease);
    overflow: hidden;
  }

  .category-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--text-1) 6%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 200ms var(--ease);
    pointer-events: none;
  }

  .category-card:hover::before {
    opacity: 1;
  }

  .category-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--text-1);
  }

  .category-card:hover .category-card-chevron {
    color: var(--text-1);
    transform: translateX(3px);
  }

  .category-card:hover .category-card-icon {
    transform: scale(1.05);
  }

  .category-card:active {
    transform: translateY(0) scale(0.98);
    transition-duration: 100ms;
  }

  .category-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-md);
    background: var(--accent-muted);
    color: var(--text-1);
    flex-shrink: 0;
    font-size: 1.125rem;
    transition: transform 250ms var(--ease);
  }

  .category-card-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text-1);
    margin: 0;
    line-height: 1.3;
  }

  .category-card-count {
    font-size: 0.75rem;
    color: var(--text-3);
    margin: 0.125rem 0 0;
  }

  .category-card-chevron {
    flex-shrink: 0;
    color: var(--text-4);
    transition: color 0.15s, transform 0.15s;
  }

  @media (max-width: 767px) {
    .category-card {
      padding: 0.875rem;
    }
  }

  @media (hover: none) {
    .category-card::before {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.matchMedia && window.matchMedia('(hover: none)').matches) return;

    var cards = document.querySelectorAll('.category-card');
    cards.forEach(function (card) {
      card.addEventListener('pointermove', function (e) {
        var rect = card.getBoundingClientRect();
        var x = ((e.clientX - rect.left) / rect.width) * 100;
        var y = ((e.clientY - rect.top) / rect.height) * 100;
        card.style.setProperty('--mx', x + '%');
        card.style.setProperty('--my', y + '%');
      });
    });
  })();
</script>
