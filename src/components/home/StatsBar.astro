---
import { getAllAPIs } from '@lib/getApis';
import type { SiteStats } from '@lib/types';

interface Props {
  stats: SiteStats;
}

const { stats } = Astro.props;
const allAPIs = getAllAPIs();
const httpsCount = allAPIs.filter((a) => a.https).length;
const corsCount = allAPIs.filter((a) => a.cors === 'yes').length;

const items = [
  { value: stats.totalAPIs.toLocaleString(), label: 'Total APIs' },
  { value: String(stats.totalCategories), label: 'Categories' },
  { value: httpsCount.toLocaleString(), label: 'With HTTPS' },
  { value: corsCount.toLocaleString(), label: 'CORS Enabled' },
];
---

<section class="statsbar">
  <div class="container statsbar-grid">
    {
      items.map((item) => (
        <div class="statsbar-item">
          <p class="statsbar-value">{item.value}</p>
          <p class="statsbar-label">{item.label}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .statsbar {
    background: var(--surface);
    padding: 1.5rem 0;
    border-block: 1px solid var(--border-subtle);
  }

  .statsbar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }

  .statsbar-item {
    transition: transform var(--t-fast);
  }

  .statsbar-item:hover .statsbar-value {
    color: var(--text-1);
  }

  .statsbar-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-1);
    margin: 0;
    font-feature-settings: 'tnum';
    letter-spacing: -0.01em;
  }

  .statsbar-label {
    font-size: 0.8125rem;
    color: var(--text-3);
    margin: 0.25rem 0 0;
  }

  @media (max-width: 639px) {
    .statsbar-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
</style>
