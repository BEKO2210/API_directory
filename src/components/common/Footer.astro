---
import { getBaseUrl } from '@lib/utils';

const base = getBaseUrl();
const year = new Date().getFullYear();

const links = [
  { label: 'Home', href: `${base}/`, external: false },
  { label: 'Search', href: `${base}/search`, external: false },
  { label: 'Guide', href: `${base}/guide`, external: false },
  { label: 'Submit API', href: `${base}/submit`, external: false },
  { label: 'About', href: `${base}/about`, external: false },
  { label: 'RSS', href: `${base}/rss.xml`, external: false },
  { label: 'Contributing', href: 'https://github.com/BEKO2210/API_directory/blob/main/CONTRIBUTING.md', external: true },
  { label: 'public-apis', href: 'https://github.com/public-apis/public-apis', external: true },
  { label: 'Fork Notice', href: 'https://github.com/BEKO2210/API_directory/blob/main/FORK_NOTICE.md', external: true },
  { label: 'Legal Notice', href: `${base}/legal-notice`, external: false },
  { label: 'Privacy', href: `${base}/privacy`, external: false },
  { label: 'Terms', href: `${base}/terms`, external: false },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-scroll" role="navigation" aria-label="Footer navigation">
      <div class="footer-links">
        <span class="footer-brand">API Hub</span>
        {
          links.map((link) => (
            <a
              href={link.href}
              {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              class="footer-link"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {year} API Hub &middot; Belkis Aslani &middot; Built on <a
          href="https://github.com/public-apis/public-apis"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-inline-link">public-apis</a
        > &middot; MIT
      </p>
      <a
        href="https://github.com/BEKO2210/API_directory"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-github"
        aria-label="Star on GitHub"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        <span>Star</span>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    margin-top: 3rem;
  }

  .footer-inner {
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Horizontal scroll row */
  .footer-scroll {
    position: relative;
    overflow: hidden;
  }

  .footer-scroll::before,
  .footer-scroll::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1.5rem;
    pointer-events: none;
    z-index: 1;
  }

  .footer-scroll::before {
    left: 0;
    background: linear-gradient(to right, var(--surface), transparent);
  }

  .footer-scroll::after {
    right: 0;
    background: linear-gradient(to left, var(--surface), transparent);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0.25rem 0;
    white-space: nowrap;
    scroll-padding-inline: 1rem;
  }

  .footer-links::-webkit-scrollbar {
    display: none;
  }

  .footer-brand {
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--text-1);
    flex-shrink: 0;
    padding-right: 0.25rem;
    border-right: 1px solid var(--border);
    margin-right: 0.25rem;
    padding-block: 0.125rem;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: var(--text-3);
    text-decoration: none;
    flex-shrink: 0;
    transition: color var(--t-fast);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--text-1);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-4);
    margin: 0;
    line-height: 1.4;
  }

  .footer-inline-link {
    color: var(--text-3);
    text-decoration: none;
  }

  .footer-inline-link:hover {
    color: var(--text-1);
  }

  .footer-github {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-3);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
    transition: color var(--t-fast), border-color var(--t-fast);
    flex-shrink: 0;
  }

  .footer-github:hover {
    color: var(--text-1);
    border-color: var(--text-4);
  }
</style>
