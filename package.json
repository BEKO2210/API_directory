{
  "name": "api-hub",
  "version": "1.0.0",
  "description": "A modern directory of free public APIs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "fetch": "node --experimental-strip-types scripts/fetch-apis.ts",
    "postbuild": "pagefind --site dist",
    "check": "astro check",
    "lint": "eslint src --ext .ts,.astro",
    "format": "prettier --write .",
    "lighthouse": "lhci autorun --config=.lighthouserc.cjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/geist": "^5.0.0",
    "@fontsource/geist-mono": "^5.0.0",
    "@playform/compress": "^0.2.3",
    "@resvg/resvg-js": "^2.6.0",
    "astro": "^6.1.8",
    "lucide-astro": "^0.453.0",
    "satori": "^0.26.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/vite": "^4.2.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.0.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@resvg/resvg-js"
    ]
  }
}