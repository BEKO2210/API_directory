{
  "name": "api-hub",
  "version": "1.0.0",
  "description": "A modern directory of free public APIs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "fetch": "node --experimental-strip-types scripts/fetch-apis.ts",
    "postbuild": "pagefind --site dist",
    "check": "astro check",
    "lint": "eslint src --ext .ts,.astro",
    "format": "prettier --write .",
    "lighthouse": "lhci autorun --config=.lighthouserc.cjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource/geist-mono": "^5.3.0",
    "@playform/compress": "^0.2.3",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.1.3",
    "satori": "^0.28.2",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.3.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@resvg/resvg-js"
    ]
  },
  "engines": {
    "node": ">=22.22.3",
    "pnpm": ">=10.0.0"
  }
}
